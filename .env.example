# Supabase credentials — get these from your Supabase project dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key-here

# LiteLLM — configure your preferred LLM provider
# For OpenAI:
OPENAI_API_KEY=sk-your-openai-key-here
# LiteLLM model identifier (e.g., gpt-4o-mini, gemini/gemini-2.0-flash, etc.)
LITELLM_MODEL=gpt-4o-mini

# Server config
HOST=0.0.0.0
PORT=8000
